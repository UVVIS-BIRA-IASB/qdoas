@article{Vandaele2002,
abstract = {High-resolution NO2 absorption cross sections have been obtained in the near-IR (NIR) and visible regions using a Fourier transform spectrometer coupled to a multiple reflection cell. Spectra were recorded at 0.05 cm\&\#8722;1 in the NIR region (10,800\&\#8211;15,100 cm\&\#8722;1) and at 0.1 cm\&\#8722;1 in the visible region (13,800\&\#8211;26,000 cm\&\#8722;1), under various pressure conditions (pure NO2 and NO2/air mixtures) and at three temperatures (220, 240, and 294 K). The effects of the temperature and the pressure on the NO2 cross sections have been investigated. As expected, an increase of temperature results in a decrease of the absorption at the maxima of the absorption bands and an increase at the minima. From the measurements performed with pure NO2 at different temperatures a linear regression of the cross section with temperature has been carried out. This enabled the cross sections to be reproduced within 2\% at room temperature and 7\% at the lower temperatures. The variation of the cross sections with the total pressure of NO2/air mixtures has also been investigated at high resolution.},
author = {Vandaele, A C and Hermans, C and Fally, S and Carleer, M and Colin, R and M�rienne, M.-F. and Jenouvrier, A and Coquart, B},
doi = {10.1029/2001JD000971},
file = {:D$\backslash$:/Users/isad/Documents/My Work/Documents/Papers and Presentations/NO2/Vandaele\_2001JD000971\_2002.pdf:pdf},
issn = {0148-0227},
journal = {Journal of Geophysical Research},
keywords = {0317 Atmospheric Composition and Structure: Chemic,0340 Atmospheric Composition and Structure: Middle,0365 Atmospheric Composition and Structure: Tropos,composition and chemistry},
month = sep,
number = {D18},
pages = {4348},
publisher = {AGU},
title = {{High-resolution Fourier transform measurement of the NO2 visible and near-infrared absorption cross sections: Temperature and pressure effects}},
url = {http://dx.doi.org/10.1029/2001JD000971},
volume = {107},
year = {2002}
}
