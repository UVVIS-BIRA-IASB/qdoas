@article{Grutter2010,
abstract = {Formic acid (HCOOH) vertical profiles have been retrieved from MIPAS-ENVISAT satellite data in the upper troposphere for the first time. Based on new spectroscopic line-strength measurements by Vander Auwera et al. (2007) of HCOOH, a retrieval setup was developed and optimized to study its global distribution between 2002 and 2008. A strong seasonality, directly associated to plant growth and corresponding biogenic emissions, is observed and dominates in the middle latitudes of the Northern Hemisphere. Here, the mean monthly volume mixing ratios (VMR) at 8 km altitude typically reach 100\&\#8211;110 parts per trillion in volume (pptv) during the summer and decrease to about 45 pptv in the early winter. At 16 km and higher altitudes, the VMRs remain under the 20 pptv level and have a much smaller amplitude (\&lt;10 pptv). In the Southern Hemisphere, strong signals (up to 1 ppbv at 10 km in a single measurement) are detected from biomass burning during the August\&\#8211;October time period and can enhance the monthly mean background levels above specific tropical and midlatitudinal regions by a factor of 2 or more. In-plume production of HCOOH through photochemical processes has been identified during an extreme event in September 2006, although it is not likely to contribute significantly to the overall upper tropospheric abundances of formic acid.},
author = {Grutter, M and Glatthor, N and Stiller, G P and Fischer, H and Grabowski, U and H\"{o}pfner, M and Kellmann, S and Linden, A and von Clarmann, T. and H�pfner, M},
doi = {10.1029/2009JD012980},
file = {:D$\backslash$:/Users/isad/Documents/My Work/Documents/Papers and Presentations/HCHO/Shen\_2009JD012810.pdf:pdf},
isbn = {0148-0227},
journal = {Journal of Geophysical Research},
keywords = {0315 Atmospheric Composition and Structure: Biosph,0345 Atmospheric Composition and Structure: Pollut,0365 Atmospheric Composition and Structure: Tropos,0478 Biogeosciences: Pollution: urban,HCOOH,MIPAS,formic acid,regional an,regional and global},
month = may,
number = {D10},
pages = {D10303},
publisher = {AGU},
title = {{Global distribution and variability of formic acid as observed by MIPAS-ENVISAT}},
url = {http://dx.doi.org/10.1029/2009JD012980 DO  - 10.1029/2009JD012980},
volume = {115},
year = {2010}
}
@article{Shen2010,
abstract = {Compound specific radiocarbon analyses of atmospheric formaldehyde are reported as fraction modern (Fm) for a limited number of winter and summer air samples collected in coastal southern New England in 2007. The 11 of 13 samples with Fm < 0.2 were collected under the influence of the semipermanent Bermuda high-pressure system with transport from the Washington, D. C., to New York City urban corridor. The two samples with Fm > 0.2 (max ∼ 0.35) were collected on days with strong northwesterly flow and the least urban impact. The Fm data were combined with VOC observations from the Rhode Island Department of Environmental Management, estimates of oxygenated VOC (OVOC), and back trajectories to interpret the relative contributions of biogenic and fossil carbon sources. It is argued that CH2O sources were dominated by pollutant VOCs and OVOCs from upwind coastal cities as opposed to more local biogenic VOCs at the times of sample collection.},
author = {Shen, Haiwei and Heikes, Brian G and Merrill, John T and McNichol, Ann P and Xu, Li},
file = {:D$\backslash$:/Users/isad/Documents/My Work/Documents/Papers and Presentations/HCHO/Shen\_2009JD012810.pdf:pdf},
isbn = {0148-0227},
journal = {Journal of Geophysical Research},
keywords = {0315 Atmospheric Composition and Structure: Biosph,0322 Atmospheric Composition and Structure: Consti,0365 Atmospheric Composition and Structure: Tropos,0368 Atmospheric Composition and Structure: Tropos,0454 Biogeosciences: Isotopic composition and chem,formaldehyde,oxygenated volatile organic compounds,ozone,radiocarbon,troposphere,volatile organic compounds},
month = may,
number = {D10},
pages = {D10301},
publisher = {AGU},
title = {{Coastal New England pilot study to determine fossil and biogenic formaldehyde source contributions using radiocarbon}},
url = {http://dx.doi.org/10.1029/2009JD012810 DO  - 10.1029/2009JD012810},
volume = {115},
year = {2010}
