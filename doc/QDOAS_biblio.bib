@article{Curci2009,
abstract = {The impact of biogenic volatile organic compound (BVOC) emissions on European ozone distributions has not yet been evaluated in a comprehensive way. Using the CHIMERE chemistry-transport model the variability of surface ozone levels from April to September for 4 years (1997, 2000, 2001, 2003) resulting from biogenic emissions is investigated. It is shown that BVOC emissions increased on average summer daily ozone maxima over Europe by 2.5\&\#xa0;ppbv (5\%). The impact is most significant in Portugal (up to 15\&\#xa0;ppbv) and in the Mediterranean region (about 5\&\#xa0;ppbv), being smaller in the northern part of Europe (1.3\&\#xa0;ppbv north of 47.5°N). The average impact is rather similar for the three summers (1997, 2000, 2001), but is much larger during the extraordinarily hot summer of 2003. Here, the biogenic contribution to surface ozone doubles compared to other years at some locations. Interaction with anthropogenic NOx emissions is found to be a key process for ozone production of biogenic precursors. Comparing the impact of the state-of-the-art BVOC emission inventory compiled within the NatAir project and an earlier, widely used BVOC inventory derived from Simpson et al. [1999. Inventorying emissions from nature in Europe. Journal of Geophysical Research 104(D7), 8113–8152] on surface ozone shows that ozone produced from biogenic precursors is less in central and northern Europe but in certain southern areas much higher e.g. Iberian Peninsula and the Mediterranean Sea. The uncertainty in the regionally averaged impact of BVOC on ozone build-up in Europe is estimated to be ±50\%.},
author = {Curci, G and Beekmann, M and Vautard, R and Smiatek, G and Steinbrecher, R and Theloke, J and Friedrich, R},
file = {:D$\backslash$:/Users/isad/Documents/My Work/Documents/Papers and Presentations/TropoChem/Curci\_1-s2.0-S1352231008002124-main.pdf:pdf},
issn = {1352-2310},
journal = {Atmospheric Environment},
keywords = {Air pollution,Biogenic emissions,Isoprene,Modelling,Ozone,Terpenes},
month = mar,
number = {7},
pages = {1444--1455},
title = {{Modelling study of the impact of isoprene and terpene biogenic emissions on European ozone levels}},
url = {http://www.sciencedirect.com/science/article/pii/S1352231008002124},
volume = {43},
year = {2009}
}
